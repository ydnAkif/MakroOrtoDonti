# Development: set true only on a local machine.
FLASK_DEBUG=true

# Required in production. Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-a-long-random-secret
ENCRYPTION_KEY=replace-with-another-long-random-secret

DATABASE_URL=sqlite:///data/makroortodonti.db
DEFAULT_ADMIN_PASSWORD=

# Enable only behind HTTPS and a trusted reverse proxy.
SESSION_COOKIE_SECURE=false
TRUST_PROXY=false

PORT=8000
WORKERS=2
LOG_LEVEL=info
